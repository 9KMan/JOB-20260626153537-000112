# =============================================================================
# Serverless Data Platform — environment variable template
# Copy to .env and fill in real values for local development.
# NEVER commit .env to source control.
# =============================================================================

# ---- AWS ---------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
AWS_ACCESS_KEY_ID=replace-with-real-access-key
AWS_SECRET_ACCESS_KEY=replace-with-real-secret-key

# ---- DynamoDB ----------------------------------------------------------------
DYNAMODB_TABLE_NAME=serverless_data_platform_core
DYNAMODB_ENDPOINT_URL=                       # leave blank for real AWS; set for localstack

# ---- S3 ----------------------------------------------------------------------
S3_UPLOADS_BUCKET=serverless-data-platform-uploads
S3_ARTIFACTS_BUCKET=serverless-data-platform-artifacts
S3_PRESIGN_EXPIRY_SECONDS=900

# ---- Cognito -----------------------------------------------------------------
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
# Set to "true" ONLY for local development to bypass signature checks.
COGNITO_AUTH_BYPASS=false

# ---- Monday.com --------------------------------------------------------------
MONDAY_API_TOKEN=replace-with-monday-api-token
MONDAY_WEBHOOK_SIGNING_SECRET=replace-with-monday-webhook-secret
MONDAY_API_VERSION=2024-01
MONDAY_DEFAULT_BOARD_ID=000000000

# ---- API ---------------------------------------------------------------------
API_BASE_URL=https://api.example.com
LOG_LEVEL=INFO

# ---- ETL ---------------------------------------------------------------------
ETL_MAX_RETRIES=3
ETL_BACKOFF_BASE_SECONDS=0.5